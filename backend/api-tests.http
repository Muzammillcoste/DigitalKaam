### DigitalKaam CRUD API Tests
# Make sure to run `npm run dev` in the backend folder first.

@baseUrl = http://127.0.0.1:3000/api

### Health Check
GET http://127.0.0.1:3000/health

### -----------------------------------------------------
### CHAT WITH AI ORCHESTRATOR
### -----------------------------------------------------

### Talk to the ADK Orchestrator
POST {{baseUrl}}/chat
Content-Type: application/json

{
  "sessionId": "test-session-123",
  "message": "I need an electrician in Gulshan"
}

### Talk to the ADK Orchestrator (Follow-up)
POST {{baseUrl}}/chat
Content-Type: application/json

{
  "sessionId": "test-session-123",
  "message": "What will be the price for fixing a fan?"
}

### -----------------------------------------------------
### 1. PROVIDERS
### -----------------------------------------------------

### List all providers
GET {{baseUrl}}/provider

### Create a new provider
POST {{baseUrl}}/provider
Content-Type: application/json

{
  "name": "Test Electrician",
  "phone": "0300-1234567",
  "email": "test@digitalkaam.pk",
  "service_type": "Electrician",
  "specialization": "General Wiring",
  "experience_years": 5,
  "hourly_rate": 800,
  "area": "Gulshan",
  "status": "active"
}

### -----------------------------------------------------
### 2. USERS
### -----------------------------------------------------

### List all users
GET {{baseUrl}}/users

### Create a new user
POST {{baseUrl}}/users
Content-Type: application/json

{
  "full_name": "Test Customer",
  "phone": "0311-9876543",
  "email": "customer@test.com",
  "home_area": "DHA"
}

### -----------------------------------------------------
### 3. BOOKINGS
### -----------------------------------------------------

### List all bookings for user
GET {{baseUrl}}/booking/user/<user-id>

### Create a booking
POST {{baseUrl}}/booking
Content-Type: application/json

{
  "provider_id": "<provider-id-here>",
  "user_id": "<user-id-here>",
  "user_request": "Need my AC fixed urgently",
  "status": "confirmed",
  "price": 1500
}

### -----------------------------------------------------
### 4. DISPUTES
### -----------------------------------------------------

### List disputes for a user
GET {{baseUrl}}/dispute/user/<user-id>

### Create a dispute
POST {{baseUrl}}/dispute
Content-Type: application/json

{
  "bookingId": "<booking-id-here>",
  "userId": "<user-id-here>",
  "providerId": "<provider-id-here>",
  "disputeType": "quality",
  "description": "Provider did not fix the issue properly"
}

### -----------------------------------------------------
### 5. AVAILABILITY
### -----------------------------------------------------

### Get availability for a provider
GET {{baseUrl}}/availability?providerId=<provider-uuid>

### Create availability slot
POST {{baseUrl}}/availability
Content-Type: application/json

{
  "provider_id": "<provider-id-here>",
  "date": "2026-05-20",
  "start_time": "10:00",
  "end_time": "12:00",
  "is_booked": false
}

### -----------------------------------------------------
### 6. REPUTATION
### -----------------------------------------------------

### List reputation for a provider
GET {{baseUrl}}/reputation?providerId=<provider-uuid>

### Create reputation record
POST {{baseUrl}}/reputation
Content-Type: application/json

{
  "provider_id": "<provider-id-here>",
  "positive_reviews": 10,
  "negative_reviews": 1,
  "complaints": 0,
  "disputes": 0
}

### -----------------------------------------------------
### 7. TRACES
### -----------------------------------------------------

### List traces
GET {{baseUrl}}/traces

### Create a trace record
POST {{baseUrl}}/traces
Content-Type: application/json

{
  "session_id": "session-123",
  "agent": "IntentAgent",
  "input": {"text": "fix AC"},
  "output": {"intent": "ac_repair"},
  "confidence_score": 0.95
}

### -----------------------------------------------------
### 8. FEEDBACK
### -----------------------------------------------------

### List feedback
GET {{baseUrl}}/feedback

### Create feedback
POST {{baseUrl}}/feedback
Content-Type: application/json

{
  "booking_id": "<booking-id-here>",
  "user_id": "<user-id-here>",
  "provider_id": "<provider-id-here>",
  "rating": 5,
  "review_text": "Great service!"
}
